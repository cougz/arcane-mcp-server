# Set USE_VPC=true to route requests through the Cloudflare VPC service binding
# (requires VPC_SERVICE binding configured in wrangler.jsonc).
# When USE_VPC=true, ARCANE_HOST is not used for routing — the VPC service
# configuration defines the destination. ARCANE_HOST is only needed locally.
USE_VPC=false
ARCANE_HOST=http://your-arcane-instance:3552
ARCANE_API_KEY=your-api-key-here
