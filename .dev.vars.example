# USE_VPC=true  → routes via Cloudflare VPC service binding (production).
#                  ARCANE_HOST is not required and is ignored.
# USE_VPC=false → routes directly to ARCANE_HOST (local dev only).
#                  ARCANE_HOST must be set or the Worker will throw on startup.
USE_VPC=false
ARCANE_HOST=http://your-arcane-instance:3552
ARCANE_API_KEY=your-api-key-here
